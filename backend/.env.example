# Environment variables configuration

# LLM Provider Configuration
LLM_PROVIDER="google" # Set to "google" or "openai"

# Google Gemini Configuration
GOOGLE_API_KEY="your-google-api-key"
GEMINI_MODEL_NAME="gemini-1.5-pro-latest"
EMBEDDING_MODEL_NAME="models/gemini-embedding-001"

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL_NAME="gpt-4o"
OPENAI_EMBEDDING_MODEL_NAME="text-embedding-3-small"

# Optional Observability Keys
ENABLE_LANGFUSE="false"
POSTHOG_API_KEY="your-posthog-api-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST="https://us.cloud.langfuse.com"

# Native Extraction vs Gemini API extraction for heavy media (video/audio)
NATIVE_MEDIA_EXTRACTION="false"

# Automatically extract and decipher images within PDFs using Gemini Vision
EXTRACT_PDF_IMAGES="true"

# Enable GraphRAG intelligent chunking and LLM entity extraction
ENABLE_GRAPHRAG="true"

# Headroom Configuration
HEADROOM_PROXY="http://127.0.0.1:8787/v1"
HEADROOM_COMPRESSION_RATIO="0.3"
HEADROOM_DISABLE_ONNX="true"

# Phoenix Configuration
PHOENIX_PROJECT_NAME="default"
PHOENIX_COLLECTOR_ENDPOINT="http://localhost:6006"