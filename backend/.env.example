# Environment variables configuration

# LLM Provider Configuration
LLM_PROVIDER="google" # Set to "google" or "openai"

# Google Gemini Configuration
GOOGLE_API_KEY="your-google-api-key"
GEMINI_MODEL_NAME="gemini-1.5-pro-latest"

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL_NAME="gpt-4o"

# Optional Observability Keys
POSTHOG_API_KEY="your-posthog-api-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST="https://us.cloud.langfuse.com"

# Native Extraction vs Gemini API extraction for heavy media (video/audio)
NATIVE_MEDIA_EXTRACTION="false"

# Automatically extract and decipher images within PDFs using Gemini Vision
EXTRACT_PDF_IMAGES="true"

# Enable GraphRAG intelligent chunking and LLM entity extraction
ENABLE_GRAPHRAG="true"
